---
import type { Stage } from '../lib/procyclingstats';

interface Props {
  stage: Stage;
  raceSlug: string;
  stageIndex: number;
}

const { stage, raceSlug, stageIndex } = Astro.props;

function formatDate(d: string) {
  if (!d) return '';
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-GB', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<section
  class="stage-section"
  id={`stage-${stageIndex}`}
  data-stage-url={stage.url}
  data-race-slug={raceSlug}
  data-distance-km={stage.distanceKm ?? ''}
>
  <div class="stage-header">
    <div class="stage-header-left">
      <h2 class="stage-label">{stage.label}</h2>
      <div class="stage-meta">
        {stage.date && <span class="stage-date">{formatDate(stage.date)}</span>}
        {stage.distanceKm && (
          <span class="stage-distance">{stage.distanceKm} km</span>
        )}
      </div>
    </div>
  </div>

  <!-- Profile image with click-to-vote overlay -->
  <div class="profile-container">
    {stage.profileImageUrl ? (
      <div class="profile-wrapper">
        <img
          src={stage.profileImageUrl}
          alt={`Route profile for ${stage.label}`}
          class="profile-image"
          loading="lazy"
        />
        <div
          class="profile-overlay"
          role="button"
          tabindex="0"
          aria-label="Click to mark where the race becomes worth watching"
          data-stage-url={stage.url}
          data-race-slug={raceSlug}
          data-distance-km={stage.distanceKm ?? ''}
        >
          <div class="profile-overlay-hint">Click to mark where it gets exciting</div>
          <!-- Colored fill: shows the "worth watching" zone after voting -->
          <div class="watch-fill" style="display:none;"></div>
          <div class="vote-marker" style="display:none;"></div>
          <!-- p25–p75 confidence band -->
          <div class="vote-band" style="display:none;"></div>
          <!-- Community vote ticks (one per vote, height = local density) -->
          <div class="vote-ticks"></div>
          <div class="consensus-line" style="display:none;"></div>
          <div class="consensus-label" style="display:none;"></div>
        </div>
      </div>
    ) : (
      <div
        class="profile-missing"
        data-stage-url={stage.url}
        data-race-slug={raceSlug}
        data-distance-km={stage.distanceKm ?? ''}
      >
        <p>
          Profile image not available.
          <a href={stage.url} target="_blank" rel="noopener">View on ProCyclingStats ↗</a>
        </p>
      </div>
    )}
  </div>

  <!-- Remove-vote button (shown by JS only when the user has voted) -->
  <div class="remove-vote-wrap" data-stage-url={stage.url} style="display:none;">
    <button class="remove-vote-btn">✕ Remove my vote</button>
  </div>

  <!-- Community vote stats (populated by client JS) -->
  <div class="vote-stats" data-stage-url={stage.url}>
    <div class="vote-stats-loading">Loading community data…</div>
  </div>

  <!-- Rating widget -->
  <div class="rating-section" data-stage-url={stage.url} data-race-slug={raceSlug}>
    <div class="rating-row">
      <span class="rating-label">Rate this stage:</span>
      <div class="star-rating" role="group" aria-label="Rate this stage from 1 to 10">
        {Array.from({ length: 10 }, (_, i) => i + 1).map((n) => (
          <button class="star-btn" data-value={n} aria-label={`${n} out of 10`}>{n}</button>
        ))}
      </div>
      <span class="rating-average">–</span>
      <span class="rating-count"></span>
    </div>
    <div class="rating-feedback" style="display:none;"></div>
  </div>
</section>
