---
import type { Stage } from '../lib/procyclingstats';

interface Props {
  stage: Stage;
  raceName: string;
  raceSlug: string;
  stageIndex: number;
  isWomen?: boolean;
}

const { stage, raceName, raceSlug, stageIndex, isWomen = false } = Astro.props;

const base = import.meta.env.BASE_URL;
// Link directly to the individual stage page
const href = `${base}race/${encodeURIComponent(raceSlug)}/${stageIndex}`;

function formatDate(d: string) {
  if (!d) return '';
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-GB', {
    weekday: 'short', day: 'numeric', month: 'short',
  });
}

const dateStr = formatDate(stage.date);
---

<a href={href} class="stage-card" data-stage-url={stage.url}>
  {stage.profileImageUrl ? (
    <div class="stage-card-img">
      <img
        src={stage.profileImageUrl}
        alt={`Route profile: ${stage.label}`}
        loading="lazy"
        class="stage-card-profile"
      />
      <!-- Community data overlay injected by JS -->
      <div class="stage-card-overlay" data-stage-url={stage.url} aria-hidden="true"></div>
    </div>
  ) : (
    <div class="stage-card-img stage-card-img--missing">
      <span>Profile loading…</span>
    </div>
  )}

  <div class="stage-card-body">
    <div class="stage-card-top">
      <span class="stage-card-race">
        {raceName}
        {isWomen && <span class="stage-card-women-badge">Women</span>}
      </span>
      <span class="stage-card-label">{stage.label}</span>
    </div>
    <div class="stage-card-meta">
      {dateStr && <span class="stage-card-date">{dateStr}</span>}
      {stage.distanceKm && (
        <span class="stage-card-dist">{stage.distanceKm} km</span>
      )}
      <span class="stage-card-votes" data-stage-url={stage.url}>
        <span class="votes-text">Loading…</span>
      </span>
    </div>
  </div>
</a>
