---
import type { Stage } from '../lib/procyclingstats';

interface Props {
  stage: Stage;
  raceName: string;
  raceSlug: string;
  stageIndex: number;
  isWomen?: boolean;
  /** Override the link href (e.g. PCS URL for upcoming races linking externally). */
  href?: string;
  /** Show an "Upcoming" badge instead of community vote count. */
  isUpcoming?: boolean;
  /** Compact horizontal layout for older/past-week cards. */
  isCompact?: boolean;
}

const { stage, raceName, raceSlug, stageIndex, isWomen = false, href: hrefOverride, isUpcoming = false, isCompact = false } = Astro.props;

const base = import.meta.env.BASE_URL;
const computedHref = `${base}race/${encodeURIComponent(raceSlug)}/${stageIndex}`;
const finalHref = hrefOverride ?? computedHref;
const isExternal = finalHref.startsWith('http');

function formatDate(d: string) {
  if (!d) return '';
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-GB', {
    weekday: 'short', day: 'numeric', month: 'short',
  });
}

const dateStr = formatDate(stage.date);
---

<a
  href={finalHref}
  class:list={['stage-card', isUpcoming && 'stage-card--upcoming', isCompact && 'stage-card--compact']}
  data-stage-url={stage.url}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener' : undefined}
>
  {stage.profileImageUrl ? (
    <div class="stage-card-img">
      <img
        src={stage.profileImageUrl}
        alt={`Route profile: ${stage.label}`}
        loading="lazy"
        class="stage-card-profile"
      />
      <!-- Community data overlay injected by JS (past stages only) -->
      {!isUpcoming && (
        <div class="stage-card-overlay" data-stage-url={stage.url} aria-hidden="true"></div>
      )}
    </div>
  ) : (
    <div class="stage-card-img stage-card-img--missing">
      <span>{isUpcoming ? 'No profile yet' : 'Profile unavailable'}</span>
    </div>
  )}

  <div class="stage-card-body">
    <div class="stage-card-top">
      <span class="stage-card-race">
        {raceName}
        {isWomen && <span class="stage-card-women-badge">Women</span>}
      </span>
      <span class="stage-card-label">{stage.label}</span>
    </div>
    <div class="stage-card-meta">
      {dateStr && <span class="stage-card-date">{dateStr}</span>}
      {stage.distanceKm && (
        <span class="stage-card-dist">{stage.distanceKm} km</span>
      )}
      {isUpcoming ? (
        <span class="stage-card-upcoming-badge">Upcoming ↗</span>
      ) : (
        <span class="stage-card-votes" data-stage-url={stage.url}>
          <span class="votes-text">Loading…</span>
        </span>
      )}
    </div>
  </div>
</a>
