---
import Layout from '../layouts/Layout.astro';
import RaceCard from '../components/RaceCard.astro';
import { getAllRaces } from '../lib/getRaces';

const { races, source } = await getAllRaces();
const usingFallback = source === 'seed';

const builtAt = new Date().toLocaleDateString('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZoneName: 'short',
});
---

<Layout title="Recent Races">
  <div class="page-header">
    <h1>Races from the last 7 days</h1>
    <p class="intro">
      Click a race to see the route profile and find out — spoiler-free —
      how many kilometres are worth watching, according to the community.
    </p>
    <p class="built-at">Last updated: {builtAt}</p>
  </div>

  {usingFallback && (
    <div class="notice-banner">
      <p>
        Live race data could not be fetched at build time (ProCyclingStats uses bot
        protection). Showing a curated list of current-season races. In production
        the site rebuilds daily via GitHub Actions, which may succeed where local
        builds don't.
      </p>
    </div>
  )}

  {!usingFallback && races.length === 0 && (
    <div class="empty-state">
      <p>No races found in the last 7 days.</p>
      <p>
        Check the full calendar on
        <a href="https://www.procyclingstats.com/races.php" target="_blank" rel="noopener">ProCyclingStats</a>.
      </p>
    </div>
  )}

  {races.length > 0 && (
    <ul class="race-list">
      {races.map((race) => (
        <li>
          <RaceCard race={race} />
        </li>
      ))}
    </ul>
  )}
</Layout>
