---
import Layout from '../layouts/Layout.astro';
import StageCard from '../components/StageCard.astro';
import { getAllRaces } from '../lib/getRaces';
import { getUpcomingStageProfiles } from '../lib/supabase';
import type { Stage } from '../lib/procyclingstats';

const { races, source } = await getAllRaces();
const usingFallback = source === 'seed';

// Flatten all stages from all races, keep race info attached
interface StageEntry {
  stage: import('../lib/procyclingstats').Stage;
  raceName: string;
  raceSlug: string;
  stageIndex: number;
  isWomen: boolean;
}

const WOMEN_KEYWORDS = ['donne', 'femmes', 'femina', 'women', 'féminin'];

function isWomensRace(name: string, slug: string): boolean {
  const n = (name + ' ' + slug).toLowerCase();
  return WOMEN_KEYWORDS.some((w) => n.includes(w));
}

const stageEntries: StageEntry[] = [];
for (const race of races) {
  const women = isWomensRace(race.name, race.slug);
  race.stages.forEach((stage, i) => {
    stageEntries.push({
      stage,
      raceName: race.name,
      raceSlug: race.slug,
      stageIndex: i,
      isWomen: women,
    });
  });
}

// Sort most recent first
stageEntries.sort((a, b) => {
  const da = a.stage.date || '';
  const db = b.stage.date || '';
  return da < db ? 1 : da > db ? -1 : 0;
});

const builtAt = new Date().toLocaleDateString('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZoneName: 'short',
});

// ── Date buckets ──────────────────────────────────────────────────────────────
const todayIso     = new Date().toISOString().slice(0, 10);
const yesterdayIso = new Date(Date.now() - 1 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
const weekAgoIso   = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

function formatDayLabel(iso: string): string {
  if (iso === todayIso)     return 'Today';
  if (iso === yesterdayIso) return 'Yesterday';
  if (iso === 'unknown')    return 'Recent';
  return new Date(iso + 'T12:00:00Z').toLocaleDateString('en-GB', {
    weekday: 'long', day: 'numeric', month: 'long',
  });
}

// Split: within the last week vs older
const recentEntries = stageEntries.filter(e => !e.stage.date || e.stage.date >= weekAgoIso);
const olderEntries  = stageEntries.filter(e =>  e.stage.date && e.stage.date <  weekAgoIso);

// Group recent entries by date, newest-first
const dayGroupMap = new Map<string, StageEntry[]>();
for (const e of recentEntries) {
  const d = e.stage.date || 'unknown';
  if (!dayGroupMap.has(d)) dayGroupMap.set(d, []);
  dayGroupMap.get(d)!.push(e);
}
const dayGroups = [...dayGroupMap.entries()]
  .sort((a, b) => b[0].localeCompare(a[0]))
  .map(([date, entries]) => ({ date, entries }));

// ── Upcoming races ────────────────────────────────────────────────────────────
const upcomingProfiles = await getUpcomingStageProfiles(new Date().getFullYear(), todayIso);

interface FutureEntry {
  stage: Stage;
  raceName: string;
  raceSlug: string;
  isWomen: boolean;
  pcsHref: string;
}

const futureEntries: FutureEntry[] = upcomingProfiles.map((p) => ({
  stage: {
    name: p.race_name ?? p.race_slug,
    label: p.stage_label ?? p.stage_full_label ?? p.race_name ?? '',
    url: p.stage_pcs_url ?? '',
    profileImageUrl: p.profile_image_url,
    distanceKm: p.distance_km != null ? Number(p.distance_km) : null,
    date: p.stage_date ?? p.race_start_date ?? '',
  },
  raceName: p.race_name ?? p.race_slug,
  raceSlug: p.race_slug,
  isWomen: WOMEN_KEYWORDS.some((w) =>
    (p.race_name ?? '' + p.race_slug).toLowerCase().includes(w)
  ),
  pcsHref: p.stage_pcs_url ?? `https://www.procyclingstats.com/race/${p.race_slug}/${p.race_year}`,
}));
---

<Layout title="Cycling Worth Watching">
  <div class="page-header">
    <h1>Cycling Worth Watching</h1>
    <p class="intro">
      Find out where races get exciting — spoiler-free. The community marks
      where to start watching and rates each stage.
    </p>
    <p class="built-at">Updated: {builtAt}</p>
  </div>

  {usingFallback && (
    <div class="notice-banner">
      Showing curated seed races — live data fetches daily via GitHub Actions.
    </div>
  )}

  {stageEntries.length === 0 && (
    <div class="empty-state">
      <p>No recent stages found. Check back soon!</p>
    </div>
  )}

  {dayGroups.map(({ date, entries }) => {
    const isToday = date === todayIso;
    return (
      <div class="day-section">
        <h2 class:list={['day-heading', isToday ? 'day-heading--today' : 'day-heading--past']}>
          {formatDayLabel(date)}
        </h2>
        {isToday ? (
          <div class="stage-grid">
            {entries.map((e) => (
              <StageCard
                stage={e.stage}
                raceName={e.raceName}
                raceSlug={e.raceSlug}
                stageIndex={e.stageIndex}
                isWomen={e.isWomen}
              />
            ))}
          </div>
        ) : (
          <div class="compact-list">
            {entries.map((e) => (
              <StageCard
                stage={e.stage}
                raceName={e.raceName}
                raceSlug={e.raceSlug}
                stageIndex={e.stageIndex}
                isWomen={e.isWomen}
                isCompact
              />
            ))}
          </div>
        )}
      </div>
    );
  })}

  {olderEntries.length > 0 && (
    <>
      <div class="show-future-wrap">
        <button id="show-older-btn" class="show-future-btn">
          Show older races
          <span class="show-future-count">{olderEntries.length}</span>
        </button>
      </div>
      <section id="older-races" hidden>
        <div class="day-section">
          <h2 class="day-heading day-heading--past">Older</h2>
          <div class="compact-list">
            {olderEntries.map((e) => (
              <StageCard
                stage={e.stage}
                raceName={e.raceName}
                raceSlug={e.raceSlug}
                stageIndex={e.stageIndex}
                isWomen={e.isWomen}
                isCompact
              />
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  {futureEntries.length > 0 && (
    <>
      <div class="show-future-wrap">
        <button id="show-future-btn" class="show-future-btn">
          Show upcoming races
          <span class="show-future-count">{futureEntries.length}</span>
        </button>
      </div>

      <section id="future-races" hidden>
        <h2 class="future-heading">Upcoming races</h2>
        <div class="stage-grid">
          {futureEntries.map((e) => (
            <StageCard
              stage={e.stage}
              raceName={e.raceName}
              raceSlug={e.raceSlug}
              stageIndex={0}
              isWomen={e.isWomen}
              href={e.pcsHref}
              isUpcoming
            />
          ))}
        </div>
      </section>
    </>
  )}
</Layout>

<script>
  import { getWatchPoints } from '../lib/supabase';

  // Load community vote counts + worth-watching badge for all stage cards
  async function loadVoteCounts() {
    const cards = document.querySelectorAll<HTMLElement>('.stage-card-votes[data-stage-url]');
    await Promise.all(Array.from(cards).map(async (el) => {
      const stageUrl = el.dataset.stageUrl!;
      const { median, count } = await getWatchPoints(stageUrl);
      const text = el.querySelector<HTMLElement>('.votes-text')!;
      const badge = el.querySelector<HTMLElement>('.vote-badge');
      if (median !== null) {
        text.textContent = `${count} vote${count !== 1 ? 's' : ''} · watch last ${median.toFixed(0)}%`;
        if (badge) {
          if (median >= 50) {
            badge.textContent = '🔥 Full race';
            badge.className = 'vote-badge vote-badge--fire';
          } else if (median <= 10) {
            badge.textContent = '🏁 Sprint finish';
            badge.className = 'vote-badge vote-badge--sprint';
          }
        }
      } else {
        text.textContent = 'No votes yet';
      }
    }));
  }

  loadVoteCounts();

  // Show older races toggle
  const olderBtn = document.getElementById('show-older-btn');
  const olderSection = document.getElementById('older-races');
  olderBtn?.addEventListener('click', () => {
    olderSection?.removeAttribute('hidden');
    olderBtn.style.display = 'none';
  });

  // Show future races toggle
  const showBtn = document.getElementById('show-future-btn');
  const futureSection = document.getElementById('future-races');
  showBtn?.addEventListener('click', () => {
    futureSection?.removeAttribute('hidden');
    showBtn.style.display = 'none';
  });
</script>
