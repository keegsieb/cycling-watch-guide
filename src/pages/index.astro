---
import Layout from '../layouts/Layout.astro';
import StageCard from '../components/StageCard.astro';
import { getAllRaces } from '../lib/getRaces';

const { races, source } = await getAllRaces();
const usingFallback = source === 'seed';

// Flatten all stages from all races, keep race info attached
interface StageEntry {
  stage: import('../lib/procyclingstats').Stage;
  raceName: string;
  raceSlug: string;
  stageIndex: number;
  isWomen: boolean;
}

const WOMEN_KEYWORDS = ['donne', 'femmes', 'femina', 'women', 'féminin'];

function isWomensRace(name: string, slug: string): boolean {
  const n = (name + ' ' + slug).toLowerCase();
  return WOMEN_KEYWORDS.some((w) => n.includes(w));
}

const stageEntries: StageEntry[] = [];
for (const race of races) {
  const women = isWomensRace(race.name, race.slug);
  race.stages.forEach((stage, i) => {
    stageEntries.push({
      stage,
      raceName: race.name,
      raceSlug: race.slug,
      stageIndex: i,
      isWomen: women,
    });
  });
}

// Sort most recent first
stageEntries.sort((a, b) => {
  const da = a.stage.date || '';
  const db = b.stage.date || '';
  return da < db ? 1 : da > db ? -1 : 0;
});

const builtAt = new Date().toLocaleDateString('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZoneName: 'short',
});
---

<Layout title="Cycling Worth Watching">
  <div class="page-header">
    <h1>Cycling Worth Watching</h1>
    <p class="intro">
      Find out where races get exciting — spoiler-free. The community marks
      where to start watching and rates each stage.
    </p>
    <p class="built-at">Updated: {builtAt}</p>
  </div>

  {usingFallback && (
    <div class="notice-banner">
      Showing curated seed races — live data fetches daily via GitHub Actions.
    </div>
  )}

  {stageEntries.length === 0 && (
    <div class="empty-state">
      <p>No recent stages found. Check back soon!</p>
    </div>
  )}

  {stageEntries.length > 0 && (
    <div class="stage-grid">
      {stageEntries.map((e) => (
        <StageCard
          stage={e.stage}
          raceName={e.raceName}
          raceSlug={e.raceSlug}
          stageIndex={e.stageIndex}
          isWomen={e.isWomen}
        />
      ))}
    </div>
  )}
</Layout>

<script>
  import { getWatchPoints } from '../lib/supabase';

  // Load community vote counts for all stage cards
  async function loadVoteCounts() {
    const cards = document.querySelectorAll<HTMLElement>('.stage-card-votes[data-stage-url]');
    await Promise.all(Array.from(cards).map(async (el) => {
      const stageUrl = el.dataset.stageUrl!;
      const { median, count } = await getWatchPoints(stageUrl);
      const text = el.querySelector('.votes-text')!;
      if (median !== null) {
        text.textContent = `${count} vote${count !== 1 ? 's' : ''} · watch last ${median.toFixed(0)}%`;
      } else {
        text.textContent = 'No votes yet';
      }
    }));
  }

  loadVoteCounts();
</script>
