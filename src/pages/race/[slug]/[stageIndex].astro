---
import Layout from '../../../layouts/Layout.astro';
import RaceProfile from '../../../components/RaceProfile.astro';
import { getAllRaces } from '../../../lib/getRaces';
import type { Race } from '../../../lib/procyclingstats';

export async function getStaticPaths() {
  const { races } = await getAllRaces();
  const paths: { params: { slug: string; stageIndex: string }; props: { race: Race; stageIndex: number } }[] = [];

  for (const race of races) {
    race.stages.forEach((_, i) => {
      paths.push({
        params: { slug: race.slug, stageIndex: String(i) },
        props: { race, stageIndex: i },
      });
    });
  }

  return paths;
}

const { race, stageIndex } = Astro.props as { race: Race; stageIndex: number };
const stage = race.stages[stageIndex];

function formatDate(d: string) {
  if (!d) return '';
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-GB', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });
}

const base = import.meta.env.BASE_URL;
const raceUrl = `${base}race/${encodeURIComponent(race.slug)}`;
const totalStages = race.stages.length;
const isStageRace = race.startDate !== race.endDate;
const prevStage = stageIndex > 0 ? `${base}race/${encodeURIComponent(race.slug)}/${stageIndex - 1}` : null;
const nextStage = stageIndex < totalStages - 1 ? `${base}race/${encodeURIComponent(race.slug)}/${stageIndex + 1}` : null;
---

<Layout
  title={`${stage.label} — ${race.name}`}
  description={`Community watch guide for ${stage.label} of ${race.name}. How many km are worth watching?`}
>
  <nav class="breadcrumb">
    <a href={`${base}`}>← All stages</a>
    {isStageRace && (
      <>
        <span class="breadcrumb-sep">·</span>
        <a href={raceUrl}>{race.name}</a>
      </>
    )}
  </nav>

  <div class="stage-page-header">
    <div class="stage-page-race">{race.name}</div>
    <h1 class="stage-page-title">{stage.label}</h1>
    <div class="stage-page-meta">
      {stage.date && <span class="stage-page-date">{formatDate(stage.date)}</span>}
      {stage.distanceKm && <span class="stage-distance">{stage.distanceKm} km</span>}
      {race.category && <span class="race-cat">{race.category}</span>}
      <button id="share-btn" class="share-btn" aria-label="Copy link to this stage">
        🔗 Share
      </button>
    </div>
  </div>

  <div class="how-to-use">
    <span class="how-to-icon">👆</span>
    <span>
      <strong>Click the profile</strong> to mark where it gets exciting.
      <strong>Rate below</strong> after watching. Green = community consensus.
    </span>
  </div>

  <!-- Single stage -->
  <RaceProfile stage={stage} raceSlug={race.slug} stageIndex={stageIndex} />

  <!-- Stage navigation for multi-stage races -->
  {isStageRace && (prevStage || nextStage) && (
    <nav class="stage-nav">
      {prevStage ? (
        <a href={prevStage} class="stage-nav-btn stage-nav-prev">← {race.stages[stageIndex - 1]?.label ?? 'Previous'}</a>
      ) : (
        <span></span>
      )}
      {nextStage && (
        <a href={nextStage} class="stage-nav-btn stage-nav-next">{race.stages[stageIndex + 1]?.label ?? 'Next'} →</a>
      )}
    </nav>
  )}
</Layout>

<script>
  import { submitWatchPoint, deleteWatchPoint, submitRating, getWatchPoints, getRatings } from '../../../lib/supabase';

  // ── localStorage helpers ────────────────────────────────────────────────
  // Keys: "cww_session"            → persistent UUID for this browser
  //        "cww_vote_<stageUrl>"   → stored pctFromFinish (number as string)
  //        "cww_rating_<stageUrl>" → stored rating value (number as string)

  function getSessionId(): string {
    let id = localStorage.getItem('cww_session');
    if (!id) {
      // crypto.randomUUID is available in all modern browsers; simple fallback for old ones
      id = typeof crypto.randomUUID === 'function'
        ? crypto.randomUUID()
        : Date.now().toString(36) + Math.random().toString(36).slice(2);
      localStorage.setItem('cww_session', id);
    }
    return id;
  }

  function getStoredVote(stageUrl: string): number | null {
    const v = localStorage.getItem(`cww_vote_${stageUrl}`);
    return v !== null ? parseFloat(v) : null;
  }
  function storeVote(stageUrl: string, pct: number) {
    localStorage.setItem(`cww_vote_${stageUrl}`, String(pct));
  }
  function clearVote(stageUrl: string) {
    localStorage.removeItem(`cww_vote_${stageUrl}`);
  }
  function getStoredRating(stageUrl: string): number | null {
    const v = localStorage.getItem(`cww_rating_${stageUrl}`);
    return v !== null ? parseInt(v, 10) : null;
  }
  function storeRating(stageUrl: string, value: number) {
    localStorage.setItem(`cww_rating_${stageUrl}`, String(value));
  }

  // ── PCS profile image offsets ────────────────────────────────────────────
  // PCS images include ~6.5% left margin (elevation axis) + ~2% right margin.
  // All pctFromFinish values stored in the DB are in "profile space" (i.e. after
  // stripping the margins), so the same constant must be applied when displaying.
  const PROFILE_LEFT  = 0.065;
  const PROFILE_RIGHT = 0.020;
  const PROFILE_W     = 1 - PROFILE_LEFT - PROFILE_RIGHT;

  /** Raw image x-fraction (0–1) → pctFromFinish in profile space (0–100). */
  function toPct(rawX: number): number {
    const adj = Math.max(0, Math.min(1, (rawX - PROFILE_LEFT) / PROFILE_W));
    return Math.round((1 - adj) * 1000) / 10;
  }

  /** pctFromFinish (0–100) → CSS left% on the full image. */
  function toLeft(pct: number): string {
    const adj = 1 - pct / 100;
    return `${(PROFILE_LEFT + adj * PROFILE_W) * 100}%`;
  }

  /** Render per-vote tick marks; height/opacity scales with local density. */
  function renderTicks(container: HTMLElement, values: number[]) {
    // Bin each vote into a 1%-wide bucket in image space
    const bins = new Map<number, number>();
    for (const v of values) {
      const imageX = PROFILE_LEFT + (1 - v / 100) * PROFILE_W;
      const bin = Math.round(imageX * 100); // 0–100 integer
      bins.set(bin, (bins.get(bin) ?? 0) + 1);
    }
    const maxCount = Math.max(...bins.values(), 1);
    const minH = 8, maxH = 34;
    container.innerHTML = '';
    for (const [bin, count] of bins) {
      const tick = document.createElement('div');
      tick.className = 'vote-tick';
      tick.style.left = `${bin}%`;
      tick.style.height = `${minH + (count / maxCount) * (maxH - minH)}px`;
      tick.style.opacity = String(0.45 + (count / maxCount) * 0.55);
      container.appendChild(tick);
    }
  }

  // ── Watch-point overlay ─────────────────────────────────────────────────

  async function initProfileOverlay(overlay: HTMLElement) {
    const stageUrl   = overlay.dataset.stageUrl!;
    const raceSlug   = overlay.dataset.raceSlug!;
    const distanceKm = overlay.dataset.distanceKm ? parseFloat(overlay.dataset.distanceKm) : null;

    const marker         = overlay.querySelector<HTMLElement>('.vote-marker')!;
    const watchFill      = overlay.querySelector<HTMLElement>('.watch-fill')!;
    const bandEl         = overlay.querySelector<HTMLElement>('.vote-band')!;
    const ticksEl        = overlay.querySelector<HTMLElement>('.vote-ticks')!;
    const consensusLine  = overlay.querySelector<HTMLElement>('.consensus-line')!;
    const consensusLabel = overlay.querySelector<HTMLElement>('.consensus-label')!;
    const hint           = overlay.querySelector<HTMLElement>('.profile-overlay-hint')!;

    /** Render the p25–p75 confidence band (needs ≥3 votes). */
    function renderBand(values: number[]) {
      if (values.length < 3) { bandEl.style.display = 'none'; return; }
      const p25 = values[Math.floor(values.length * 0.25)];
      const p75 = values[Math.floor(values.length * 0.75)];
      // p75 is further from finish → further LEFT on the image
      bandEl.style.left  = toLeft(p75);
      // right edge: distance from right = PROFILE_RIGHT + (p25/100)*PROFILE_W
      bandEl.style.right = `${(PROFILE_RIGHT + (p25 / 100) * PROFILE_W) * 100}%`;
      bandEl.style.display = 'block';
    }

    // Load community data and render ticks + median line + confidence band
    const { median, count, values } = await getWatchPoints(stageUrl);
    if (values.length > 0) renderTicks(ticksEl, values);
    renderBand(values);
    if (median !== null) {
      consensusLine.style.left = toLeft(median);
      consensusLine.style.display = 'block';
      const label = distanceKm
        ? `Watch from ${Math.round((median / 100) * distanceKm)} km to go · ${count} vote${count !== 1 ? 's' : ''}`
        : `Last ${median.toFixed(0)}% · ${count} vote${count !== 1 ? 's' : ''}`;
      consensusLabel.textContent = label;
      consensusLabel.style.display = 'block';
    }

    const statsEl = document.querySelector<HTMLElement>(
      `.vote-stats[data-stage-url="${CSS.escape(stageUrl)}"]`
    );
    if (statsEl) {
      if (median !== null) {
        const kmText = distanceKm
          ? `${Math.round((median / 100) * distanceKm)} km from the finish`
          : `${median.toFixed(0)}% from the finish`;
        statsEl.innerHTML = `
          <div class="vote-summary">
            <span class="vote-count-badge">${count} vote${count !== 1 ? 's' : ''}</span>
            Community says: start watching from <strong>${kmText}</strong>.
          </div>`;
      } else {
        statsEl.innerHTML = `<div class="vote-summary no-votes">No votes yet — be the first to click the profile above!</div>`;
      }
    }

    // Remove-vote button wiring
    const removeWrap = document.querySelector<HTMLElement>(
      `.remove-vote-wrap[data-stage-url="${CSS.escape(stageUrl)}"]`
    );
    const removeBtn = removeWrap?.querySelector<HTMLButtonElement>('.remove-vote-btn');

    function showRemoveBtn() {
      if (removeWrap) removeWrap.style.display = 'flex';
    }
    function hideRemoveBtn() {
      if (removeWrap) removeWrap.style.display = 'none';
    }

    function clearVoteUI() {
      marker.style.display = 'none';
      watchFill.style.display = 'none';
      hint.textContent = 'Click to mark where it gets exciting';
      hint.classList.remove('hint-submitted');
      hideRemoveBtn();
    }

    // Restore previous vote marker (overlay stays interactive — click to update)
    const previousVote = getStoredVote(stageUrl);
    if (previousVote !== null) {
      marker.style.left = toLeft(previousVote);
      marker.style.display = 'block';
      watchFill.style.left = toLeft(previousVote);
      watchFill.style.right = '0';
      watchFill.style.display = 'block';
      hint.textContent = '✓ Voted · click to update';
      hint.classList.add('hint-submitted');
      showRemoveBtn();
    }

    removeBtn?.addEventListener('click', async () => {
      removeBtn.disabled = true;
      const { error } = await deleteWatchPoint(stageUrl, getSessionId());
      if (error) {
        removeBtn.disabled = false;
        return;
      }
      clearVote(stageUrl);
      clearVoteUI();
      // Refresh community ticks/stats/band
      const { median, count, values } = await getWatchPoints(stageUrl);
      ticksEl.innerHTML = '';
      if (values.length > 0) renderTicks(ticksEl, values);
      renderBand(values);
      if (median !== null) {
        consensusLine.style.left = toLeft(median);
        consensusLine.style.display = 'block';
        const label = distanceKm
          ? `Watch from ${Math.round((median / 100) * distanceKm)} km to go · ${count} vote${count !== 1 ? 's' : ''}`
          : `Last ${median.toFixed(0)}% · ${count} vote${count !== 1 ? 's' : ''}`;
        consensusLabel.textContent = label;
        consensusLabel.style.display = 'block';
      } else {
        consensusLine.style.display = 'none';
        consensusLabel.style.display = 'none';
      }
      if (statsEl) {
        if (median !== null) {
          const kmText = distanceKm
            ? `${Math.round((median / 100) * distanceKm)} km from the finish`
            : `${median.toFixed(0)}% from the finish`;
          statsEl.innerHTML = `
            <div class="vote-summary">
              <span class="vote-count-badge">${count} vote${count !== 1 ? 's' : ''}</span>
              Community says: start watching from <strong>${kmText}</strong>.
            </div>`;
        } else {
          statsEl.innerHTML = `<div class="vote-summary no-votes">No votes yet — be the first to click the profile above!</div>`;
        }
      }
    });

    async function handleVote(e: MouseEvent | KeyboardEvent) {
      if (e instanceof KeyboardEvent && e.key !== 'Enter' && e.key !== ' ') return;
      const rect = overlay.getBoundingClientRect();
      const clientX = e instanceof MouseEvent ? e.clientX : rect.left + rect.width / 2;
      const rawX = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      const pctFromFinish = toPct(rawX);
      const imageLeft = toLeft(pctFromFinish);

      // Update UI immediately
      marker.style.left = imageLeft;
      marker.style.display = 'block';
      watchFill.style.left = imageLeft;
      watchFill.style.right = '0';
      watchFill.style.display = 'block';
      hint.textContent = '✓ Voted · click to update';
      hint.classList.add('hint-submitted');
      storeVote(stageUrl, pctFromFinish);
      showRemoveBtn();

      await submitWatchPoint(raceSlug, stageUrl, pctFromFinish, getSessionId());
    }

    overlay.addEventListener('click', handleVote);
    overlay.addEventListener('keydown', handleVote);
  }

  // ── Rating widget ───────────────────────────────────────────────────────

  async function initRatingWidget(section: HTMLElement) {
    const stageUrl   = section.dataset.stageUrl!;
    const raceSlug   = section.dataset.raceSlug!;
    const averageEl  = section.querySelector<HTMLElement>('.rating-average')!;
    const countEl    = section.querySelector<HTMLElement>('.rating-count')!;
    const feedbackEl = section.querySelector<HTMLElement>('.rating-feedback')!;

    const { average, count } = await getRatings(stageUrl);
    averageEl.textContent = average !== null ? `${average}/10` : '–';
    if (count > 0) countEl.textContent = `(${count} rating${count !== 1 ? 's' : ''})`;

    // If already rated, restore selected star and lock buttons
    const previousRating = getStoredRating(stageUrl);
    if (previousRating !== null) {
      section.querySelectorAll<HTMLButtonElement>('.star-btn').forEach((btn) => {
        btn.setAttribute('disabled', 'true');
        if (parseInt(btn.dataset.value!, 10) === previousRating) btn.classList.add('selected');
      });
      feedbackEl.textContent = `You rated this ${previousRating}/10.`;
      feedbackEl.style.display = 'block';
      return;
    }

    section.querySelectorAll<HTMLButtonElement>('.star-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const value = parseInt(btn.dataset.value!, 10);
        // Lock immediately to prevent double-submit
        section.querySelectorAll('.star-btn').forEach((b) => b.setAttribute('disabled', 'true'));
        const { error } = await submitRating(raceSlug, stageUrl, value);
        if (error) {
          feedbackEl.textContent = `Could not save rating: ${error}`;
          // Unlock on error so they can retry
          section.querySelectorAll<HTMLButtonElement>('.star-btn').forEach((b) => b.removeAttribute('disabled'));
        } else {
          storeRating(stageUrl, value);
          feedbackEl.textContent = `Thanks! You rated this ${value}/10.`;
          btn.classList.add('selected');
          const updated = await getRatings(stageUrl);
          if (updated.average !== null) {
            averageEl.textContent = `${updated.average}/10`;
            countEl.textContent = `(${updated.count} rating${updated.count !== 1 ? 's' : ''})`;
          }
        }
        feedbackEl.style.display = 'block';
      });
    });
  }

  document.querySelectorAll<HTMLElement>('.profile-overlay').forEach(initProfileOverlay);
  document.querySelectorAll<HTMLElement>('.rating-section').forEach(initRatingWidget);

  // ── Share button ─────────────────────────────────────────────────────────
  const shareBtn = document.getElementById('share-btn') as HTMLButtonElement | null;
  shareBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const orig = shareBtn.textContent!;
      shareBtn.textContent = '✓ Copied!';
      shareBtn.classList.add('share-btn--copied');
      setTimeout(() => {
        shareBtn.textContent = orig;
        shareBtn.classList.remove('share-btn--copied');
      }, 2000);
    } catch {
      // Fallback: select a temporary input
      const inp = document.createElement('input');
      inp.value = window.location.href;
      document.body.appendChild(inp);
      inp.select();
      document.execCommand('copy');
      document.body.removeChild(inp);
    }
  });
</script>
