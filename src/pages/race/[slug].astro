---
import Layout from '../../layouts/Layout.astro';
import RaceProfile from '../../components/RaceProfile.astro';
import { getFullRace } from '../../lib/procyclingstats';
import { getAllRaces } from '../../lib/getRaces';
import type { Race } from '../../lib/procyclingstats';

export async function getStaticPaths() {
  const { races } = await getAllRaces();
  return races.map((race) => ({
    params: { slug: race.slug },
    props: { race },
  }));
}

const { race: raceBase } = Astro.props as { race: Race };

// Fetch full race details (stages + profile images) at build time
let race: Race = raceBase;
try {
  race = await getFullRace(raceBase);
} catch (err) {
  console.error(`Failed to fetch full race for ${raceBase.slug}:`, err);
}

// If no stages were loaded (PCS blocked), build a placeholder entry
// so the race page still has something to render.
if (race.stages.length === 0) {
  race = {
    ...race,
    stages: [{
      name: race.name,
      label: race.startDate === race.endDate ? race.name : `${race.name} (all stages)`,
      url: race.url,
      profileImageUrl: null,
      distanceKm: null,
      date: race.endDate,
    }],
  };
}

function formatDate(d: string) {
  if (!d) return '';
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

const isStageRace = race.startDate !== race.endDate;
const base = import.meta.env.BASE_URL;
---

<Layout
  title={race.name}
  description={`Community watch guide for ${race.name}. How many km are worth watching?`}
>
  <nav class="breadcrumb">
    <a href={`${base}`}>← All races</a>
  </nav>

  <div class="race-page-header">
    <h1>{race.name}</h1>
    <div class="race-dates">
      {isStageRace ? (
        <span>{formatDate(race.startDate)} – {formatDate(race.endDate)}</span>
      ) : (
        <span>{formatDate(race.endDate)}</span>
      )}
      {race.category && <span class="race-cat">{race.category}</span>}
    </div>
    <a href={race.url} target="_blank" rel="noopener" class="pcs-link">
      View on ProCyclingStats ↗
    </a>
  </div>

  <div class="how-to-use">
    <h2>How to use this page</h2>
    <ol>
      <li>
        <strong>Click on the route profile</strong> at the point where you think the race
        starts getting exciting. The further left you click, the more of the race you're
        recommending people watch.
      </li>
      <li><strong>Rate the stage</strong> from 1 to 10 after you've watched it.</li>
      <li>
        The <strong>community consensus marker</strong> shows the median of all votes —
        that's your spoiler-free start point.
      </li>
    </ol>
  </div>

  <div class="stages-list">
    {race.stages.map((stage) => (
      <RaceProfile stage={stage} raceSlug={race.slug} />
    ))}
  </div>
</Layout>

<!-- Client-side: profile image loading, voting, and community data -->
<script>
  import { submitWatchPoint, submitRating, getWatchPoints, getRatings } from '../../lib/supabase';
  import { buildProfileImageCandidates, parseStageUrl } from '../../lib/profileUrls';

  // ─── Profile images ───────────────────────────────────────────────────────
  // PCS serves profile images as static files. When the server-side fetch is
  // blocked by Cloudflare, the browser can often load them directly because
  // the user's browser already has valid PCS cookies from real visits.

  function tryLoadProfileImages() {
    document.querySelectorAll<HTMLElement>('.profile-missing').forEach((placeholder) => {
      const section = placeholder.closest<HTMLElement>('.stage-section');
      if (!section) return;
      const stageUrl = section.dataset.stageUrl;
      const raceSlug = section.dataset.raceSlug;
      if (!stageUrl) return;

      const parsed = parseStageUrl(stageUrl);
      if (!parsed) return;

      const candidates = buildProfileImageCandidates(parsed.slug, parsed.year, parsed.stageNumber);
      let tried = 0;

      function tryNext() {
        if (tried >= candidates.length) return;
        const url = candidates[tried++];
        const img = new Image();
        img.onload = () => {
          const container = placeholder.closest('.profile-container');
          if (!container) return;
          const distKm = section.dataset.distanceKm ?? '';
          container.innerHTML = `
            <div class="profile-wrapper">
              <img src="${url}" alt="Route profile" class="profile-image" />
              <div class="profile-overlay"
                   role="button" tabindex="0"
                   aria-label="Click to mark where the race becomes worth watching"
                   data-stage-url="${stageUrl}"
                   data-race-slug="${raceSlug ?? ''}"
                   data-distance-km="${distKm}">
                <div class="profile-overlay-hint">👆 Click to mark where it gets exciting</div>
                <div class="vote-marker" style="display:none;"></div>
                <div class="consensus-line" style="display:none;"></div>
                <div class="consensus-label" style="display:none;"></div>
              </div>
            </div>`;
          const overlay = container.querySelector<HTMLElement>('.profile-overlay');
          if (overlay) initProfileOverlay(overlay);
        };
        img.onerror = tryNext;
        img.src = url;
      }
      tryNext();
    });
  }

  // ─── Watch-point voting ───────────────────────────────────────────────────

  async function initProfileOverlay(overlay: HTMLElement) {
    const stageUrl = overlay.dataset.stageUrl!;
    const raceSlug = overlay.dataset.raceSlug!;
    const distanceKm = overlay.dataset.distanceKm ? parseFloat(overlay.dataset.distanceKm) : null;
    const marker = overlay.querySelector<HTMLElement>('.vote-marker')!;
    const consensusLine = overlay.querySelector<HTMLElement>('.consensus-line')!;
    const consensusLabel = overlay.querySelector<HTMLElement>('.consensus-label')!;
    const hint = overlay.querySelector<HTMLElement>('.profile-overlay-hint')!;

    const { median, count } = await getWatchPoints(stageUrl);
    if (median !== null) {
      // PCS profiles: finish is on the right → leftPct = 100 - median
      consensusLine.style.left = `${100 - median}%`;
      consensusLine.style.display = 'block';
      const label = distanceKm
        ? `Community: watch from ${Math.round((median / 100) * distanceKm)} km to go (${count} vote${count !== 1 ? 's' : ''})`
        : `Community: ${median.toFixed(0)}% from finish (${count} vote${count !== 1 ? 's' : ''})`;
      consensusLabel.textContent = label;
      consensusLabel.style.display = 'block';
    }

    // Update the vote-stats block below the profile
    const statsEl = document.querySelector<HTMLElement>(`.vote-stats[data-stage-url="${CSS.escape(stageUrl)}"]`);
    if (statsEl) {
      if (median !== null) {
        const kmText = distanceKm
          ? `${Math.round((median / 100) * distanceKm)} km from the finish`
          : `${median.toFixed(0)}% from the finish`;
        statsEl.innerHTML = `
          <p class="vote-summary">
            <strong>${count} ${count === 1 ? 'person has' : 'people have'} voted.</strong>
            Community says: start watching from <strong>${kmText}</strong>.
          </p>`;
      } else {
        statsEl.innerHTML = `<p class="vote-summary no-votes">No votes yet — be the first!</p>`;
      }
    }

    async function handleVote(e: MouseEvent | KeyboardEvent) {
      if (e instanceof KeyboardEvent && e.key !== 'Enter' && e.key !== ' ') return;
      const rect = overlay.getBoundingClientRect();
      const clientX = e instanceof MouseEvent ? e.clientX : rect.left + rect.width / 2;
      const xFraction = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      const pctFromFinish = Math.round((1 - xFraction) * 1000) / 10;

      marker.style.left = `${xFraction * 100}%`;
      marker.style.display = 'block';
      hint.textContent = '✓ Vote submitted!';

      const { error } = await submitWatchPoint(raceSlug, stageUrl, pctFromFinish);
      if (error) hint.textContent = `Could not save vote: ${error}`;
    }

    overlay.addEventListener('click', handleVote);
    overlay.addEventListener('keydown', handleVote);
  }

  // ─── Star ratings ─────────────────────────────────────────────────────────

  async function initRatingWidget(section: HTMLElement) {
    const stageUrl = section.dataset.stageUrl!;
    const raceSlug = section.dataset.raceSlug!;
    const averageEl = section.querySelector<HTMLElement>('.rating-average')!;
    const countEl = section.querySelector<HTMLElement>('.rating-count')!;
    const feedbackEl = section.querySelector<HTMLElement>('.rating-feedback')!;

    const { average, count } = await getRatings(stageUrl);
    averageEl.textContent = average !== null ? `${average}/10` : 'No ratings yet';
    if (count > 0) countEl.textContent = `(${count} rating${count !== 1 ? 's' : ''})`;

    section.querySelectorAll<HTMLButtonElement>('.star-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const value = parseInt(btn.dataset.value!, 10);
        section.querySelectorAll('.star-btn').forEach((b) => b.setAttribute('disabled', 'true'));
        const { error } = await submitRating(raceSlug, stageUrl, value);
        if (error) {
          feedbackEl.textContent = `Could not save rating: ${error}`;
        } else {
          feedbackEl.textContent = `Thanks! You rated this ${value}/10.`;
          btn.classList.add('selected');
          const updated = await getRatings(stageUrl);
          if (updated.average !== null) {
            averageEl.textContent = `${updated.average}/10`;
            countEl.textContent = `(${updated.count} rating${updated.count !== 1 ? 's' : ''})`;
          }
        }
        feedbackEl.style.display = 'block';
      });
    });
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────

  tryLoadProfileImages();
  document.querySelectorAll<HTMLElement>('.profile-overlay').forEach(initProfileOverlay);
  document.querySelectorAll<HTMLElement>('.rating-section').forEach(initRatingWidget);
</script>
